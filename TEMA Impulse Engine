//@version=6
indicator("TEMA Impulse Engine (Anti-Exhaustion v6.2)", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// 1. VSTUPNÍ PARAMETRY (USER INPUTS)
// ==========================================
string triggerMode = input.string("Price vs TEMA", title="Režim Vstupu (Trigger)", options=["TEMA Crossover", "Price vs TEMA"], group="1. Výkonnostní Režim")

int fastPeriod = input.int(9, title="Rychlá TEMA (Trigger)", minval=1, group="2. TEMA Nastavení")
int slowPeriod = input.int(21, title="Pomalá TEMA (Trend)", minval=1, group="2. TEMA Nastavení")

// Anti-Exhaustion (Ochrana proti rozjetému vlaku na konci momentum svíčky)
bool useExhaustionFilter = input.bool(true, title="Zapnout Ochranu proti Vyčerpání (Anti-Exhaustion)", group="3. Ochrana proti okamžitému PEAKu")
float maxTemaDistanceAtr = input.float(0.8, title="Max. vzdálenost od TEMA (Násobitel ATR)", step=0.1, group="3. Ochrana proti okamžitému PEAKu")

bool useSessionFilter = input.bool(false, title="Obchodovat pouze v Killzones", group="4. Časové Okna")
string session1 = input.session("0900-1130:23456", title="London Session", group="4. Časové Okna")
string session2 = input.session("1430-1700:23456", title="New York Session", group="4. Časové Okna")

bool useAdxFilter = input.bool(false, title="Zapnout ADX Filtr (Ochrana Chop)", group="5. Filtry Volatility")
int adxLength = input.int(14, title="ADX Perioda", minval=1, group="5. Filtry Volatility")
int adxThreshold = input.int(22, title="Minimální ADX", minval=1, group="5. Filtry Volatility")

bool useBreakoutFilter = input.bool(false, title="Zapnout Průraz Struktury", group="5. Filtry Volatility")
int breakoutLookback = input.int(3, title="Lookback pro Průraz", minval=2, group="5. Filtry Volatility")

bool useHtfFilter = input.bool(true, title="Zapnout HTF Trend Filtr (M15)", group="6. Globální Kontext")
string htfResolution = input.timeframe("15", title="HTF Časový rámec", group="6. Globální Kontext")
int htfEmaPeriod = input.int(200, title="HTF EMA Perioda", group="6. Globální Kontext")

float trailingAtrMultiplier = input.float(1.5, title="Trailing SL Násobitel ATR", step=0.1, group="7. Výstupy")
float slMoveMilestoneRrr = input.float(1.0, title="Milník pro posun SL (RRR)", step=0.1, group="7. Výstupy")
int peakStallBars = input.int(2, title="Peak stall bary", minval=1, maxval=8, group="7. Výstupy", tooltip="Kolik barů bez nového high/low než se PEAK potvrdí.")
float minPeakAtr = input.float(0.5, title="Min zisk pro PEAK (× ATR)", step=0.1, minval=0.1, group="7. Výstupy", tooltip="PEAK se neukáže dokud trend nemá alespoň tento zisk od vstupu.")
bool showEntryLabels = input.bool(true, title="Štítky BUY/SELL", group="8. Vizualizace")
bool showPeakLabels = input.bool(true, title="Štítek PEAK", group="8. Vizualizace")
bool showEndLabels = input.bool(true, title="Štítky END", group="8. Vizualizace")

// ==========================================
// 2. GLOBÁLNÍ VÝPOČTY
// ==========================================
custom_tema(src, length) =>
    ema1 = ta.ema(src, length)
    ema2 = ta.ema(ema1, length)
    ema3 = ta.ema(ema2, length)
    3 * ema1 - 3 * ema2 + ema3

fastTema = custom_tema(close, fastPeriod)
slowTema = custom_tema(close, slowPeriod)

plot(fastTema, color=fastTema > slowTema ? color.new(#00ffff, 30) : color.new(#ff00ff, 30), linewidth=2, title="Rychlá TEMA")
plot(slowTema, color=color.new(#95a5a6, 70), linewidth=1, title="Pomalá TEMA")

currentAtr = ta.atr(14)

// OPRAVA: abs() změněno na math.abs() pro v6 kompatibilitu
temaDistance = math.abs(close - fastTema)
maxAllowedDistance = currentAtr * maxTemaDistanceAtr
notExhausted = not useExhaustionFilter or (temaDistance <= maxAllowedDistance)

[diPlus, diMinus, adxVal] = ta.dmi(adxLength, adxLength)
adxTrending = not useAdxFilter or (adxVal > adxThreshold)

highestHigh = ta.highest(high, breakoutLookback)[1]
lowestLow = ta.lowest(low, breakoutLookback)[1]
breakoutLong = not useBreakoutFilter or (close > highestHigh)
breakoutShort = not useBreakoutFilter or (close < lowestLow)

inSession = not useSessionFilter or (not na(time(timeframe.period, session1, "GMT+2")) or not na(time(timeframe.period, session2, "GMT+2")))
htfEmaRaw = ta.ema(close, htfEmaPeriod)
htfEma = request.security(syminfo.tickerid, htfResolution, htfEmaRaw, gaps=barmerge.gaps_off)

trendLong = not useHtfFilter or (close > htfEma)
trendShort = not useHtfFilter or (close < htfEma)

bool buyCondition = false
bool sellCondition = false

if triggerMode == "TEMA Crossover"
    buyCondition := ta.crossover(fastTema, slowTema)
    sellCondition := ta.crossunder(fastTema, slowTema)
else
    buyCondition := ta.crossover(close, fastTema)
    sellCondition := ta.crossunder(close, fastTema)

buyTrigger = buyCondition and trendLong and inSession and adxTrending and breakoutLong and notExhausted
sellTrigger = sellCondition and trendShort and inSession and adxTrending and breakoutShort and notExhausted

// ==========================================
// 3. STRIKTNÍ ROZHODOVACÍ ENGINE (BAR CLOSE)
// ==========================================
var float entryPrice = na
var float initialRisk = na
var float activeTrailingSL = na
var int marketState = 0 
var bool slMovedToBE = false

var float peakPrice = na
var int peakBarIndex = na
var int peakStallCount = 0
var bool peakConfirmed = false
var label activePeakLabel = na
var line activePeakLine = na

rsiPeak = ta.rsi(close, 14)

// Historické složky PEAK — každý bar (Pine konzistence)
rsiRollLong = rsiPeak < rsiPeak[1]
rsiRollShort = rsiPeak > rsiPeak[1]
rejectionLong = close < open and not na(peakPrice) and high >= peakPrice
rejectionShort = close > open and not na(peakPrice) and low <= peakPrice
peakSignalLong = rsiRollLong or rejectionLong
peakSignalShort = rsiRollShort or rejectionShort

f_draw_peak_label(bool isLong, int pkBar, float pk, float offset) =>
    lbl = isLong ? label.new(pkBar, pk + offset, "PEAK", yloc=yloc.price, color=#9b59b6, style=label.style_label_down, textcolor=color.white, size=size.small) : label.new(pkBar, pk - offset, "PEAK", yloc=yloc.price, color=#9b59b6, style=label.style_label_up, textcolor=color.white, size=size.small)
    ln = isLong ? line.new(pkBar, pk, pkBar, pk + offset, color=#9b59b6, style=line.style_dotted, width=1) : line.new(pkBar, pk, pkBar, pk - offset, color=#9b59b6, style=line.style_dotted, width=1)
    [lbl, ln]

f_clear_peak_visuals(label lbl, line ln) =>
    if not na(lbl)
        label.delete(lbl)
    if not na(ln)
        line.delete(ln)

bool actualBuy = false
bool actualSell = false
bool finalEndLong = false
bool finalEndShort = false

float labelOffset = currentAtr * 0.8

if barstate.isconfirmed
    if marketState == 1
        if high > peakPrice
            peakPrice := high
            peakBarIndex := bar_index
            peakStallCount := 0
            if peakConfirmed
                peakConfirmed := false
                f_clear_peak_visuals(activePeakLabel, activePeakLine)
                activePeakLabel := na
                activePeakLine := na
        else
            peakStallCount += 1

        peakReadyLong = not na(entryPrice) and close - entryPrice >= minPeakAtr * currentAtr and peakStallCount >= peakStallBars and peakSignalLong
        if showPeakLabels and not peakConfirmed and peakReadyLong
            peakConfirmed := true
            [lbl, ln] = f_draw_peak_label(true, peakBarIndex, peakPrice, labelOffset)
            activePeakLabel := lbl
            activePeakLine := ln

        targetPeak = entryPrice + (initialRisk * slMoveMilestoneRrr)
        if not slMovedToBE and high >= targetPeak
            slMovedToBE := true
            activeTrailingSL := entryPrice 
        
        newSL = close - (currentAtr * trailingAtrMultiplier)
        if slMovedToBE
            if newSL > activeTrailingSL
                activeTrailingSL := newSL
        else
            if newSL > activeTrailingSL
                activeTrailingSL := newSL
                
        if close < activeTrailingSL
            finalEndLong := true
            marketState := 0
            activeTrailingSL := na
            entryPrice := na
            slMovedToBE := false
            peakConfirmed := false
            peakStallCount := 0
            f_clear_peak_visuals(activePeakLabel, activePeakLine)
            activePeakLabel := na
            activePeakLine := na

    else if marketState == -1
        if low < peakPrice
            peakPrice := low
            peakBarIndex := bar_index
            peakStallCount := 0
            if peakConfirmed
                peakConfirmed := false
                f_clear_peak_visuals(activePeakLabel, activePeakLine)
                activePeakLabel := na
                activePeakLine := na
        else
            peakStallCount += 1

        peakReadyShort = not na(entryPrice) and entryPrice - close >= minPeakAtr * currentAtr and peakStallCount >= peakStallBars and peakSignalShort
        if showPeakLabels and not peakConfirmed and peakReadyShort
            peakConfirmed := true
            [lbl, ln] = f_draw_peak_label(false, peakBarIndex, peakPrice, labelOffset)
            activePeakLabel := lbl
            activePeakLine := ln

        targetPeak = entryPrice - (initialRisk * slMoveMilestoneRrr)
        if not slMovedToBE and low <= targetPeak
            slMovedToBE := true
            activeTrailingSL := entryPrice
            
        newSL = close + (currentAtr * trailingAtrMultiplier)
        if slMovedToBE
            if newSL < activeTrailingSL
                activeTrailingSL := newSL
        else
            if newSL < activeTrailingSL
                activeTrailingSL := newSL
                
        if close > activeTrailingSL
            finalEndShort := true
            marketState := 0
            activeTrailingSL := na
            entryPrice := na
            slMovedToBE := false
            peakConfirmed := false
            peakStallCount := 0
            f_clear_peak_visuals(activePeakLabel, activePeakLine)
            activePeakLabel := na
            activePeakLine := na

    else if marketState == 0
        if buyTrigger
            marketState := 1
            entryPrice := close
            initialRisk := currentAtr * trailingAtrMultiplier
            activeTrailingSL := close - initialRisk
            slMovedToBE := false
            actualBuy := true
            
            peakPrice := high
            peakBarIndex := bar_index
            peakStallCount := 0
            peakConfirmed := false
            
        else if sellTrigger
            marketState := -1
            entryPrice := close
            initialRisk := currentAtr * trailingAtrMultiplier
            activeTrailingSL := close + initialRisk
            slMovedToBE := false
            actualSell := true
            
            peakPrice := low
            peakBarIndex := bar_index
            peakStallCount := 0
            peakConfirmed := false

// ==========================================
// 4. FLOATING ŠTÍTKY S UKOTVENÍM (UI/UX)
// ==========================================
barcolor(barstate.isconfirmed ? (actualBuy ? #00ff00 : actualSell ? #ff0000 : (finalEndLong or finalEndShort) ? #f1c40f : na) : na)

if barstate.isconfirmed
    if actualBuy and showEntryLabels
        labelY = low - labelOffset
        label.new(bar_index, labelY, "BUY", yloc=yloc.price, color=#2ecc71, style=label.style_label_up, textcolor=color.white, size=size.small)
        line.new(bar_index, low, bar_index, labelY, color=#2ecc71, style=line.style_dotted, width=1)

    if finalEndShort and showEndLabels
        labelY = low - labelOffset
        label.new(bar_index, labelY, "END", yloc=yloc.price, color=#f1c40f, style=label.style_label_up, textcolor=color.black, size=size.small)
        line.new(bar_index, low, bar_index, labelY, color=#f1c40f, style=line.style_dotted, width=1)

    if actualSell and showEntryLabels
        labelY = high + labelOffset
        label.new(bar_index, labelY, "SELL", yloc=yloc.price, color=#e74c3c, style=label.style_label_down, textcolor=color.white, size=size.small)
        line.new(bar_index, high, bar_index, labelY, color=#e74c3c, style=line.style_dotted, width=1)

    if finalEndLong and showEndLabels
        labelY = high + labelOffset
        label.new(bar_index, labelY, "END", yloc=yloc.price, color=#f1c40f, style=label.style_label_down, textcolor=color.black, size=size.small)
        line.new(bar_index, high, bar_index, labelY, color=#f1c40f, style=line.style_dotted, width=1)

plot(marketState != 0 ? activeTrailingSL : na, title="Dynamic Protected SL", color=slMovedToBE ? #00ffff : (marketState == 1 ? color.green : color.red), style=plot.style_line, linewidth=2)

// ==========================================
// 5. HUD DASHBOARD
// ==========================================
var table hud = table.new(position.top_right, 2, 5, bgcolor=color.new(#111116, 15), border_color=#2c3e50, border_width=1)
if barstate.islast
    table.cell(hud, 0, 0, "Engine Mode: " + triggerMode, text_color=color.white, text_size=size.small, bgcolor=#1a1a24)
    table.cell(hud, 1, 0, "Stav (Live Close)", text_color=color.white, text_size=size.small, bgcolor=#1a1a24)
    
    table.cell(hud, 0, 1, "Pozice v Trhu", text_color=color.white, text_size=size.small)
    table.cell(hud, 1, 1, marketState == 1 ? "LONG" : marketState == -1 ? "SHORT" : "FLAT", bgcolor=marketState == 1 ? color.green : marketState == -1 ? color.red : color.gray, text_color=color.white, text_size=size.small)
    
    table.cell(hud, 0, 2, "Zajištění Rizika", text_color=color.white, text_size=size.small)
    table.cell(hud, 1, 2, marketState == 0 ? "Flat" : slMovedToBE ? "RISK-FREE (BE)" : "ÚVODNÍ RISK", bgcolor=marketState == 0 ? color.gray : slMovedToBE ? color.teal : color.orange, text_color=color.white, text_size=size.small)
               
    table.cell(hud, 0, 3, "Vzdálenost od TEMA", text_color=color.white, text_size=size.small)
    table.cell(hud, 1, 3, temaDistance <= maxAllowedDistance ? "ZDRAVÁ (" + str.tostring(temaDistance / currentAtr, "#.##") + " ATR)" : "EXHAUSTION PAST", bgcolor=temaDistance <= maxAllowedDistance ? color.green : color.red, text_color=color.white, text_size=size.small)

    table.cell(hud, 0, 4, "M15 Vyšší Trend", text_color=color.white, text_size=size.small)
    table.cell(hud, 1, 4, close > htfEma ? "BULLISH" : "BEARISH", bgcolor=close > htfEma ? color.green : color.red, text_color=color.white, text_size=size.small)